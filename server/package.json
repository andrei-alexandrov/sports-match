{
  "name": "@sports-match/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:memory": "tsx src/dev-memory.ts",
    "test": "vitest run",
    "build": "tsc --noEmit && esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --packages=external --alias:@sports-match/shared=../shared/src/index.ts"
  },
  "dependencies": {
    "@sports-match/shared": "*",
    "bcryptjs": "^3.0.2",
    "compression": "^1.8.1",
    "connect-mongo": "^5.1.0",
    "dotenv": "^16.4.5",
    "express": "^5.1.0",
    "express-rate-limit": "^8.5.2",
    "express-session": "^1.18.1",
    "mongoose": "^8.16.0",
    "socket.io": "^4.8.0"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.0",
    "@types/express-session": "^1.18.0",
    "@types/node": "^24.0.0",
    "@types/supertest": "^6.0.0",
    "esbuild": "^0.28.1",
    "mongodb-memory-server": "^10.1.0",
    "socket.io-client": "^4.8.0",
    "supertest": "^7.1.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0",
    "zod": "^4.0.0"
  }
}
